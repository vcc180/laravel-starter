{
  "name": "vcc180/laravel-starter",
  "description": "Starter Laravel admin com RBAC e repositório modular",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "laravel/framework": "^11"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Core\\": "core/",
      "Core\\Discovery\\": "core/Discovery",
      "Core\\Exceptions\\": "core/Exceptions",
      "Core\\Managers\\": "core/Managers",
      "Core\\Registry\\": "core/Registry",
      "Core\\Support\\": "core/Support",
      "Database\\Seeders\\": "database/seeders/",
      "Modules\\Blog\\": "modules/blog/src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi"
    ]
  },
  "extra": {
    "laravel": {
      "providers": []
    }
  }
}
